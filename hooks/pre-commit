#!/bin/bash
echo "Running pre-commit checks..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED_FILES" ]; then
    echo "No files staged for commit"
    exit 0
fi

CHECKS_FAILED=0

# --- Security checks (universal) ---

echo "→ Checking for .env files..."
if echo "$STAGED_FILES" | grep -E "\.env$|\.env\."; then
    FORBIDDEN_ENV_FILES=$(echo "$STAGED_FILES" | grep -E "\.env$|\.env\." | grep -v "\.env\.example$")
    if [ -n "$FORBIDDEN_ENV_FILES" ]; then
        echo "Commit rejected: .env file detected"
        echo "$FORBIDDEN_ENV_FILES"
        exit 1
    fi
fi

echo "→ Scanning for secrets..."
SECRET_PATTERNS=(
    "API_KEY" "APIKEY" "SECRET" "TOKEN" "PASSWORD"
    "PRIVATE_KEY" "AWS_ACCESS_KEY" "AWS_SECRET" "CLIENT_SECRET"
)
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        for pattern in "${SECRET_PATTERNS[@]}"; do
            if grep -qE "${pattern}\s*=\s*['\"]?[a-zA-Z0-9+/]{16,}" "$file"; then
                echo "Commit rejected: potential secret in $file (matched: $pattern)"
                exit 1
            fi
        done
    fi
done

# --- Formatting (Prettier for common file types) ---

PRETTIER_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx|js|jsx|json|md|css|scss|html|yaml|yml)$' || true)
if [ -n "$PRETTIER_FILES" ]; then
    if command -v npx &> /dev/null; then
        echo "→ Running Prettier..."
        for file in $PRETTIER_FILES; do
            if ! npx prettier --check "$file" 2>/dev/null; then
                CHECKS_FAILED=1
            fi
        done
        if [ $CHECKS_FAILED -eq 1 ]; then
            echo "Run 'npx prettier --write <file>' to auto-fix"
            exit 1
        fi
    else
        echo "npx not found — skipping Prettier"
    fi
fi

# --- Add project-specific checks below ---
#
# Uncomment or add checks that match your project's stack:
#
# ESLint (JavaScript/TypeScript):
#   npx eslint "$file"
#
# ruff (Python linting):
#   ruff check "$file"
#
# black (Python formatting):
#   black --check "$file"
#
# go vet (Go):
#   go vet ./...
#
# clippy (Rust):
#   cargo clippy -- -D warnings

# --- Result ---

if [ $CHECKS_FAILED -eq 0 ]; then
    echo "All pre-commit checks passed"
    exit 0
else
    echo "Pre-commit checks failed"
    exit 1
fi
