#!/bin/bash
commit_msg=$(cat "$1")

AI_TOOLS="claude|cursor|copilot|cody|aider|gemini|codex|chatgpt|gpt-[34]"
matched_tool=$(echo "$commit_msg" | grep -ioE "$AI_TOOLS" | head -1)
if [ -n "$matched_tool" ]; then
    echo "Commit rejected: message contains AI tool name '$matched_tool'"
    exit 1
fi

first_char=$(echo "$commit_msg" | head -c 1)
if [[ "$first_char" =~ ^[A-Z]$ ]]; then
    echo "Commit rejected: message must start with lowercase letter"
    exit 1
fi

exit 0
